# Copy to deploy.env and fill in once. deploy.env is gitignored.
# Supabase Dashboard → Account → Access Tokens
SUPABASE_ACCESS_TOKEN=sbp_your_token_here

# Supabase Dashboard → Project Settings → General → Reference ID
SUPABASE_PROJECT_REF=your_project_ref_here

# Optional: cloud project URL (for .env.local in backend)
# SUPABASE_URL=https://xxxx.supabase.co

# Cursor Cloud Agents API (Dashboard → API Keys) — used by CRM self-heal code-fix queue
# CURSOR_API_KEY=key_xxxxxxxx
