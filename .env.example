# Copy to .env.local for local development.
#
# The frontend no longer embeds API handlers — all /api/* and /webhooks/* traffic
# is proxied to the tradepro-backend companion (sibling checkout, port 3001).

# ── Frontend (this repo) ─────────────────────────────────────────────────────

# REQUIRED for dev: canonical backend the Vite dev server proxies /api/* and
# /webhooks/* to. Start it with: cd ../tradepro-backend && npm run dev
VITE_API_BASE_URL=http://localhost:3001

# Supabase (frontend — anon key only, never service role)
VITE_SUPABASE_URL=https://xxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...

# Demo login (set false in production)
# Real accounts only — set true only for local UI demos without dedicated credentials
VITE_DEMO_LOGIN=false

# ── Server-only — configure in tradepro-backend/.env, NOT here ───────────────
# Everything below is read by the tradepro-backend server process. It is kept
# here for reference during the migration; the frontend dev server no longer
# loads these. Super Admin configures live values in Settings → Integrations.

# OpenAI (Cynthia — staff, web/portal/WhatsApp, and phone)
OPENAI_API_KEY=sk-your-key-here
# Optional alternate text brain (Integrations → Company AI Brain overrides env)
DEEPSEEK_API_KEY=

# WhatsApp — live transport is WhatsApp Web.js (QR in Integrations). Path B Meta is cold forever.
# Do NOT set WHATSAPP_META_ENABLED=true in production. Leave Meta secrets blank.
WHATSAPP_META_ENABLED=false
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=tradepro_verify
META_APP_SECRET=

# Voice Telephony (Cynthia phone AI — Vapi only; configure in tradepro-backend/.env)
VOICE_PROVIDER=vapi
TELEPHONY_PROVIDER=vapi
# Soho66 credentials feed the Vapi SIP trunk (not local sip-bridge AI)
SOHO66_SIP_USERNAME=
SOHO66_SIP_PASSWORD=
SOHO66_SIP_DOMAIN=sbc.soho66.co.uk
SOHO66_FROM_NUMBER=
VOICE_TRANSFER_NUMBER=
VOICE_WEBHOOK_VERIFY_TOKEN=tradepro_voice_verify
VOICE_AFTER_HOURS=0
VOICE_BUSINESS_HOURS_START=09:00
VOICE_BUSINESS_HOURS_END=17:30
WEBHOOK_BASE_URL=
# Local: http://localhost:5174 — Production: https://app.b-diddies.com
APP_BASE_URL=http://localhost:5174
# Production host for Builder Diddies product app (deploy scripts use this):
# APP_BASE_URL=https://app.b-diddies.com
# WEBHOOK_BASE_URL=https://app.b-diddies.com
# Marketing / Company Profile website for B-Diddies home org: https://b-diddies.com

# Chatterbox TTS (Cynthia phone cloned voices on VPS — e.g. Cockney/Del Boy accent)
CHATTERBOX_BASE_URL=
CHATTERBOX_API_KEY=
# Synth endpoint path on your Chatterbox server (default /tts)
CHATTERBOX_TTS_PATH=/tts

# Email (SMTP) — dev fallback for real sending via server/messages-routes.ts
# Live values are configured in Settings → Integrations → Email (SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=Builder Diddies
SMTP_SECURE=true

# Mailbox OAuth (Gmail / Outlook / Yahoo via XOAUTH2 IMAP+SMTP)
# Generate 32-byte hex: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TOKEN_ENCRYPTION_KEY=
MAILBOX_OAUTH_REDIRECT_BASE=http://localhost:5176
MAILBOX_POLL_INTERVAL_MS=180000
# Production: require Bearer JWT on /api/mailbox/* (keep false for local mock)
AUTH_ENFORCED=false
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
MICROSOFT_OAUTH_CLIENT_ID=
MICROSOFT_OAUTH_CLIENT_SECRET=
MICROSOFT_OAUTH_TENANT=common
YAHOO_OAUTH_CLIENT_ID=
YAHOO_OAUTH_CLIENT_SECRET=
# Optional Nylas fallback (MAILBOX_PROVIDER=nylas)
NYLAS_API_KEY=
NYLAS_CLIENT_ID=

# Price Research (live local price lookup for AI job pricing)
# Provider: openai_web (uses OPENAI_API_KEY), tavily, or serper
PRICE_RESEARCH_PROVIDER=openai_web
PRICE_RESEARCH_API_KEY=
PRICE_RESEARCH_REGION=UK

# Global mock mode (true = simulate all outbound messages)
INTEGRATIONS_MOCK_MODE=true

# Standalone server port (tradepro-backend server/index.ts)
PORT=3001

# Stripe (platform SaaS + customer deposits / contract stages)
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_STARTER=
# STRIPE_PRICE_PRO=
# STRIPE_PRICE_ENTERPRISE=
