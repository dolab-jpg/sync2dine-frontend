# Dev fallbacks — Super Admin configures live values in Settings → Integrations
# Copy to .env.local for local development

# OpenAI (TradePro AI + Cyrus + Aria phone agent)
OPENAI_API_KEY=sk-your-key-here

# WhatsApp Business (Meta Cloud API)
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=tradepro_verify
META_APP_SECRET=

# Voice Telephony (Aria AI phone agent)
# Provider: mock (dev/test) or soho66 (SIP multi-line)
TELEPHONY_PROVIDER=soho66
# Jambonz/FreeSWITCH bridge URL — registers all lines from Call Centre → Phone Lines
SOHO66_SIP_BRIDGE_URL=
# Legacy single-line env (auto-migrates to Phone Lines on first run)
SOHO66_SIP_USERNAME=
SOHO66_SIP_PASSWORD=
SOHO66_SIP_DOMAIN=sip.soho66.com
SOHO66_FROM_NUMBER=
VOICE_TRANSFER_NUMBER=
VOICE_WEBHOOK_VERIFY_TOKEN=tradepro_voice_verify
VOICE_AFTER_HOURS=0
VOICE_BUSINESS_HOURS_START=09:00
VOICE_BUSINESS_HOURS_END=17:30
WEBHOOK_BASE_URL=
APP_BASE_URL=http://localhost:5174

# Chatterbox TTS (Aria cloned voices on VPS — e.g. Cockney/Del Boy accent)
CHATTERBOX_BASE_URL=
CHATTERBOX_API_KEY=
# Synth endpoint path on your Chatterbox server (default /tts)
CHATTERBOX_TTS_PATH=/tts

# MongoDB (recommended for go-live — server-side data for phone agent)
# Without MongoDB, call/customer data lives in server/data/synced-data.json
MONGODB_CONNECTION_STRING=

# Email (SMTP) — dev fallback for real sending via server/messages-routes.ts
# Live values are configured in Settings → Integrations → Email (SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=TradePro
SMTP_SECURE=true

# Mailbox OAuth (Gmail / Outlook / Yahoo via XOAUTH2 IMAP+SMTP)
# Generate 32-byte hex: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TOKEN_ENCRYPTION_KEY=
MAILBOX_OAUTH_REDIRECT_BASE=http://localhost:5174
MAILBOX_POLL_INTERVAL_MS=180000
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
MICROSOFT_OAUTH_CLIENT_ID=
MICROSOFT_OAUTH_CLIENT_SECRET=
MICROSOFT_OAUTH_TENANT=common
YAHOO_OAUTH_CLIENT_ID=
YAHOO_OAUTH_CLIENT_SECRET=
# Optional Nylas fallback (MAILBOX_PROVIDER=nylas)
NYLAS_API_KEY=
NYLAS_CLIENT_ID=

# Price Research (live local price lookup for AI job pricing)
# Provider: openai_web (uses OPENAI_API_KEY), tavily, or serper
PRICE_RESEARCH_PROVIDER=openai_web
PRICE_RESEARCH_API_KEY=
PRICE_RESEARCH_REGION=UK

# Global mock mode (true = simulate all outbound messages)
INTEGRATIONS_MOCK_MODE=true

# Standalone server port (server/index.ts)
PORT=3001

# Supabase (frontend — anon key only, never service role)
VITE_SUPABASE_URL=https://xxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...

# Node companion for AI/webhooks (tradepro-backend repo)
VITE_API_BASE_URL=http://localhost:3001

# Demo login (set false in production)
VITE_DEMO_LOGIN=true
